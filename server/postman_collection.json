{
  "info": {
    "name": "Template Gestionale API",
    "description": "Collection per testare le API del backend Express.\n\nCome usarla:\n1. Postman → File → Import → seleziona questo file.\n2. La variabile `baseUrl` punta a http://localhost:3000: per testare il deploy cambiala con il dominio Railway (tab Variables della collection).\n3. Esegui `Auth / Login`: il token JWT viene salvato automaticamente nella variabile `token` e usato da tutte le rotte protette.\n\nCredenziali di test (create da `npm run seed`): admin@test.it / Admin123! — utente@test.it / Utente123!\n\nQuando aggiungi una risorsa al progetto, aggiungi qui la sua cartella di richieste (vedi ADDING_A_RESOURCE.md).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "ticketId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.ok && res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('Token salvato nella variabile {{token}}');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"first_name\": \"Mario\",\n    \"last_name\": \"Rossi\",\n    \"email\": \"mario.rossi@test.it\",\n    \"password\": \"Password123!\",\n    \"repeatPassword\": \"Password123!\",\n    \"isAdmin\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Registrazione pubblica. Salva automaticamente il token restituito."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.ok && res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('Token salvato nella variabile {{token}}');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@test.it\",\n    \"password\": \"Admin123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Login. Salva automaticamente il token nella variabile della collection: le altre richieste lo usano via Bearer."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            },
            "description": "Dati dell'utente autenticato (dal token). Protetta."
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Logout stateless: risponde ok, l'invalidazione del token è a carico del client."
          }
        }
      ]
    },
    {
      "name": "Users (solo admin)",
      "description": "Tutte le rotte richiedono token di un utente admin (fai prima Login con admin@test.it).",
      "item": [
        {
          "name": "Lista utenti",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          }
        },
        {
          "name": "Dettaglio utente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "uuid dell'utente"
                }
              ]
            }
          }
        },
        {
          "name": "Crea utente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"first_name\": \"Luigi\",\n    \"last_name\": \"Verdi\",\n    \"email\": \"luigi.verdi@test.it\",\n    \"password\": \"Password123!\",\n    \"isAdmin\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          }
        },
        {
          "name": "Aggiorna utente",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"first_name\": \"Luigi\",\n    \"last_name\": \"Verdi\",\n    \"email\": \"luigi.verdi@test.it\",\n    \"isAdmin\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "uuid dell'utente"
                }
              ]
            },
            "description": "password opzionale: aggiungerla al body solo per cambiarla."
          }
        },
        {
          "name": "Elimina utente",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "uuid dell'utente"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Ticket",
      "description": "Rotte protette. Il richiedente vede/modifica solo i propri ticket (404 altrimenti) e solo finche sono `open` (409 altrimenti). Le rotte azione (prendi-in-carico / risolvi / rifiuta) richiedono un token da tecnico (isAdmin: true). Imposta le variabili di collection `categoryId` e `ticketId` prima di usarle.",
      "item": [
        {
          "name": "Lista ticket",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ticket",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ticket"
              ]
            },
            "description": "Il richiedente vede solo i propri, il tecnico li vede tutti."
          }
        },
        {
          "name": "Lista ticket (con filtri)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ticket?status=open&priority=high&categoryId={{categoryId}}&month=2026-07&page=1&limit=20&sort=created_at&order=desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ticket"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "open",
                  "description": "open | in_progress | resolved | rejected"
                },
                {
                  "key": "priority",
                  "value": "high",
                  "description": "low | medium | high | urgent"
                },
                {
                  "key": "categoryId",
                  "value": "{{categoryId}}",
                  "description": "uuid categoria"
                },
                {
                  "key": "month",
                  "value": "2026-07",
                  "description": "YYYY-MM, sulla data di apertura (ha precedenza su dateFrom/dateTo)"
                },
                {
                  "key": "dateFrom",
                  "value": "",
                  "description": "periodo: data apertura >= (ISO). Ignorato se month e valido",
                  "disabled": true
                },
                {
                  "key": "dateTo",
                  "value": "",
                  "description": "periodo: data apertura <= (ISO). Ignorato se month e valido",
                  "disabled": true
                },
                {
                  "key": "requesterId",
                  "value": "",
                  "description": "uuid richiedente — SOLO tecnico",
                  "disabled": true
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "pagina (1-based), default 1"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "elementi per pagina, default 20, max 100"
                },
                {
                  "key": "sort",
                  "value": "created_at",
                  "description": "created_at | priority | status | taken_in_charge_at | resolved_at"
                },
                {
                  "key": "order",
                  "value": "desc",
                  "description": "asc | desc"
                }
              ]
            },
            "description": "Elenco paginato con filtri (standard FILTERS_BE.md). Tutti i parametri sono opzionali. `month` ha precedenza sul periodo `dateFrom`/`dateTo`. `requesterId` e onorato solo per i tecnici: per un richiedente e ignorato (vede solo i propri ticket). Risposta: { data, pagination: { total, page, limit, totalPages } }."
          }
        },
        {
          "name": "Dettaglio ticket",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ticket/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ticket",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "{{ticketId}}",
                  "description": "uuid del ticket"
                }
              ]
            }
          }
        },
        {
          "name": "Crea ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n        \"title\": \"PC non si accende\",\n        \"description\": \"Il computer dell ufficio 2 non da segni di vita.\",\n        \"category_id\": \"{{categoryId}}\",\n        \"priority\": \"high\"\n    }"
            },
            "url": {
              "raw": "{{baseUrl}}/ticket",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ticket"
              ]
            },
            "description": "`requester_id` viene dal token e `status` e forzato a `open`: non vanno passati nel body."
          }
        },
        {
          "name": "Aggiorna ticket",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n        \"title\": \"PC non si accende (aggiornato)\",\n        \"description\": \"Aggiornamento: non si accende nemmeno con un altro cavo.\",\n        \"category_id\": \"{{categoryId}}\",\n        \"priority\": \"urgent\"\n    }"
            },
            "url": {
              "raw": "{{baseUrl}}/ticket/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ticket",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "{{ticketId}}",
                  "description": "uuid del ticket"
                }
              ]
            },
            "description": "Solo il richiedente proprietario e solo se il ticket e ancora `open`."
          }
        },
        {
          "name": "Elimina ticket",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ticket/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ticket",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "{{ticketId}}",
                  "description": "uuid del ticket"
                }
              ]
            },
            "description": "Solo il richiedente proprietario e solo se il ticket e ancora `open`."
          }
        },
        {
          "name": "Prendi in carico (solo tecnico)",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ticket/:id/take-in-charge",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ticket",
                ":id",
                "take-in-charge"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "{{ticketId}}",
                  "description": "uuid del ticket"
                }
              ]
            },
            "description": "`open` -> `in_progress`. Assegna il ticket al tecnico autenticato e imposta `taken_in_charge_at`."
          }
        },
        {
          "name": "Risolvi (solo tecnico)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n        \"worked_hours\": 2.5,\n        \"resolution_note\": \"Sostituito alimentatore.\"\n    }"
            },
            "url": {
              "raw": "{{baseUrl}}/ticket/:id/risolvi",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ticket",
                ":id",
                "risolvi"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "{{ticketId}}",
                  "description": "uuid del ticket"
                }
              ]
            },
            "description": "`in_progress` -> `resolved`. `worked_hours` obbligatorie (> 0, max 9999.99). `resolution_note` opzionale."
          }
        },
        {
          "name": "Rifiuta (solo tecnico)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n        \"rejection_reason\": \"Richiesta non di competenza dell assistenza tecnica.\"\n    }"
            },
            "url": {
              "raw": "{{baseUrl}}/ticket/:id/rifiuta",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ticket",
                ":id",
                "rifiuta"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "{{ticketId}}",
                  "description": "uuid del ticket"
                }
              ]
            },
            "description": "`open` | `in_progress` -> `rejected`. `rejection_reason` obbligatoria."
          }
        }
      ]
    },
    {
      "name": "Utility",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Verifica che il server sia su. Pubblica."
          }
        }
      ]
    }
  ]
}
